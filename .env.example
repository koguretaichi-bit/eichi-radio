# このファイルを .env にコピーして、使うものだけ入れてください。
# .env は .gitignore で除外されるので公開リポジトリに上がりません。

# === 無料スタック（推奨） =========================================
# 台本生成: Google Gemini 無料枠（クレカ不要）
#   キー取得: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# 音声(Edge TTS)は APIキー不要。何も書かなくてOK。

# === 有料スタックを使う場合だけ ===================================
# config.yaml で provider を claude / openai にしたとき必要
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
